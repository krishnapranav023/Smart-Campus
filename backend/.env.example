PORT=5000
DATABASE_URL="mysql://root:password@localhost:3306/multi_institution_events"
JWT_SECRET="your_jwt_secret_key_here"

# ─── SMTP Email Configuration ─────────────────────────────────────────────────
# Gmail: SMTP_HOST=smtp.gmail.com | SMTP_PORT=587 | Use App Password (not regular password)
# Outlook: SMTP_HOST=smtp-mail.outlook.com | SMTP_PORT=587
# Leave blank to operate in mock/local-log mode
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Inter-Collegiate Event Portal <no-reply@yourdomain.edu.in>"
